<%- include('../partials/header') %>

<div class="main">
  <div class="topbar">
    <span class="page-title">📊 Dashboard</span>
  </div>
  <div class="content">

    <% if (success && success.length > 0) { %>
      <div class="alert alert-success"><%= success[0] %></div>
    <% } %>

    <!-- Stats Grid -->
    <div class="stats-grid">
      <div class="stat-card blue">
        <div class="stat-label">Total Produk</div>
        <div class="stat-value mono"><%= productStats.total_products %></div>
        <div class="stat-sub">item terdaftar</div>
      </div>
      <div class="stat-card green">
        <div class="stat-label">Total Stok</div>
        <div class="stat-value mono"><%= productStats.total_stock.toLocaleString('id-ID') %></div>
        <div class="stat-sub">unit tersedia</div>
      </div>
      <div class="stat-card orange">
        <div class="stat-label">Nilai Inventori</div>
        <div class="stat-value mono" style="font-size:1.2rem;">Rp <%= Math.floor(productStats.total_inventory_value / 1000000) %>Jt</div>
        <div class="stat-sub">estimasi total nilai</div>
      </div>
      <div class="stat-card red">
        <div class="stat-label">Stok Rendah</div>
        <div class="stat-value mono"><%= productStats.low_stock_count + productStats.out_of_stock_count %></div>
        <div class="stat-sub">produk perlu restock</div>
      </div>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:24px;">
      <!-- Category Distribution -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">Distribusi Kategori</span>
        </div>
        <div class="card-body">
          <% categoryDistribution.forEach(function(cat) { %>
            <div style="margin-bottom:14px;">
              <div style="display:flex; justify-content:space-between; margin-bottom:5px;">
                <span style="font-size:0.85rem; color:var(--text2);"><%= cat.name %></span>
                <span style="font-size:0.8rem; color:var(--text3); font-family:'JetBrains Mono',monospace;"><%= cat.count %> produk (<%= cat.percent %>%)</span>
              </div>
              <div style="height:6px; background:var(--surface2); border-radius:3px; overflow:hidden;">
                <div style="height:100%; width:<%= cat.percent %>%; background:var(--accent); border-radius:3px; transition:width 0.5s;"></div>
              </div>
            </div>
          <% }); %>
        </div>
      </div>

      <!-- Recent Char Checker Logs -->
      <div class="card">
        <div class="card-header">
          <span class="card-title">Log Character Checker</span>
          <a href="/char-checker" class="btn btn-sm btn-secondary">Buka Tool</a>
        </div>
        <div class="card-body" style="padding:0;">
          <% if (recentLogs.length === 0) { %>
            <p style="color:var(--text3); font-size:0.85rem; padding:16px; text-align:center;">Belum ada log</p>
          <% } else { %>
            <table>
              <thead><tr><th>Input 1</th><th>Input 2</th><th>Tipe</th><th>Hasil</th></tr></thead>
              <tbody>
                <% recentLogs.forEach(function(log) { %>
                  <tr>
                    <td class="mono" style="color:var(--accent);"><%= log.input1 %></td>
                    <td class="mono" style="max-width:100px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;"><%= log.input2 %></td>
                    <td><span class="badge <%= log.type === 'sensitive' ? 'badge-warning' : 'badge-info' %>"><%= log.type === 'sensitive' ? 'CS' : 'CI' %></span></td>
                    <td class="mono" style="color:var(--success);"><%= log.percentage %>%</td>
                  </tr>
                <% }); %>
              </tbody>
            </table>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Price Stats -->
    <div class="card">
      <div class="card-header">
        <span class="card-title">Statistik Harga Produk</span>
      </div>
      <div class="card-body">
        <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:16px;">
          <div style="text-align:center; padding:16px; background:var(--surface2); border-radius:10px;">
            <div style="font-size:0.72rem; color:var(--text3); text-transform:uppercase; letter-spacing:0.05em;">Harga Max</div>
            <div class="mono" style="font-size:1.1rem; font-weight:700; color:var(--success); margin-top:6px;">Rp <%= productStats.max_price.toLocaleString('id-ID') %></div>
          </div>
          <div style="text-align:center; padding:16px; background:var(--surface2); border-radius:10px;">
            <div style="font-size:0.72rem; color:var(--text3); text-transform:uppercase; letter-spacing:0.05em;">Harga Min</div>
            <div class="mono" style="font-size:1.1rem; font-weight:700; color:var(--warning); margin-top:6px;">Rp <%= productStats.min_price.toLocaleString('id-ID') %></div>
          </div>
          <div style="text-align:center; padding:16px; background:var(--surface2); border-radius:10px;">
            <div style="font-size:0.72rem; color:var(--text3); text-transform:uppercase; letter-spacing:0.05em;">Rata-rata Stok</div>
            <div class="mono" style="font-size:1.1rem; font-weight:700; color:var(--accent); margin-top:6px;"><%= productStats.avg_stock %> unit</div>
          </div>
          <div style="text-align:center; padding:16px; background:var(--surface2); border-radius:10px;">
            <div style="font-size:0.72rem; color:var(--text3); text-transform:uppercase; letter-spacing:0.05em;">Habis Stok</div>
            <div class="mono" style="font-size:1.1rem; font-weight:700; color:var(--danger); margin-top:6px;"><%= productStats.out_of_stock_count %> produk</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('../partials/footer') %>
