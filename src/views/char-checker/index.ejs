<%- include('../partials/header') %>
<div class="main">
  <div class="topbar"><span class="page-title">🔤 Character Checker</span></div>
  <div class="content">
    <% if (error && error.length > 0) { %><div class="alert alert-danger"><%= error[0] %></div><% } %>

    <div class="page-header">
      <h1>Character Percentage Checker</h1>
    </div>

    <div style="display:grid; grid-template-columns:1fr 1fr; gap:20px; margin-bottom:24px;">
      <!-- Input Form -->
      <div class="card">
        <div class="card-header"><span class="card-title">Input</span></div>
        <div class="card-body">
          <form action="/char-checker" method="POST">
            <div class="form-group">
              <label class="form-label">Input 1 (sumber karakter)</label>
              <input type="text" name="input1" class="form-control mono" value="<%= input1 %>" placeholder="Contoh: ABBCD" required/>
              <div style="font-size:0.75rem; color:var(--text3); margin-top:4px;">Karakter unik dari input ini akan dicek</div>
            </div>
            <div class="form-group">
              <label class="form-label">Input 2 (teks pembanding)</label>
              <input type="text" name="input2" class="form-control mono" value="<%= input2 %>" placeholder="Contoh: Gallant Duck" required/>
              <div style="font-size:0.75rem; color:var(--text3); margin-top:4px;">Dicek apakah karakter input 1 muncul di sini</div>
            </div>
            <div class="form-group">
              <label class="form-label">Tipe Pengecekan</label>
              <div style="display:flex; gap:12px; margin-top:6px;">
                <label style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:10px 16px; background:var(--surface2); border-radius:8px; border:1px solid <%= type === 'sensitive' ? 'var(--accent)' : 'var(--border)' %>;">
                  <input type="radio" name="type" value="sensitive" <%= type === 'sensitive' ? 'checked' : '' %> style="accent-color:var(--accent);"/>
                  <div>
                    <div style="font-size:0.85rem; font-weight:600; color:var(--text);">Case Sensitive</div>
                    <div style="font-size:0.72rem; color:var(--text3);">'A' ≠ 'a'</div>
                  </div>
                </label>
                <label style="display:flex; align-items:center; gap:8px; cursor:pointer; padding:10px 16px; background:var(--surface2); border-radius:8px; border:1px solid <%= type === 'insensitive' ? 'var(--accent)' : 'var(--border)' %>;">
                  <input type="radio" name="type" value="insensitive" <%= type === 'insensitive' ? 'checked' : '' %> style="accent-color:var(--accent);"/>
                  <div>
                    <div style="font-size:0.85rem; font-weight:600; color:var(--text);">Case Insensitive</div>
                    <div style="font-size:0.72rem; color:var(--text3);">'A' = 'a'</div>
                  </div>
                </label>
              </div>
            </div>
            <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center; padding:12px;">Cek Sekarang →</button>
          </form>
        </div>
      </div>

      <!-- Result -->
      <div class="card">
        <div class="card-header"><span class="card-title">Hasil</span></div>
        <div class="card-body">
          <% if (!result) { %>
            <div style="text-align:center; padding:40px 20px; color:var(--text3);">
              <div style="font-size:2rem; margin-bottom:12px;">🔍</div>
              <div style="font-size:0.9rem;">Masukkan dua teks dan pilih tipe pengecekan untuk melihat hasil</div>
            </div>
          <% } else { %>
            <!-- Big percentage display -->
            <div style="text-align:center; padding:20px; margin-bottom:20px; background:var(--surface2); border-radius:12px; border:1px solid var(--border);">
              <div style="font-size:0.75rem; color:var(--text3); text-transform:uppercase; letter-spacing:0.08em; margin-bottom:8px;">Persentase Kecocokan</div>
              <div style="font-size:3rem; font-weight:700; font-family:'JetBrains Mono',monospace; color:<%= result.percentage >= 50 ? 'var(--success)' : result.percentage > 0 ? 'var(--warning)' : 'var(--danger)' %>;">
                <%= result.percentage %>%
              </div>
              <div style="font-size:0.85rem; color:var(--text2); margin-top:8px;" class="mono">
                <%= result.percentage_display %>
              </div>
              <div style="margin-top:10px;">
                <span class="badge badge-<%= result.type === 'Case Sensitive' ? 'warning' : 'info' %>"><%= result.type %></span>
              </div>
            </div>

            <!-- Progress bar -->
            <div style="margin-bottom:16px;">
              <div style="height:8px; background:var(--surface2); border-radius:4px; overflow:hidden;">
                <div style="height:100%; width:<%= result.percentage %>%; background:linear-gradient(90deg, var(--accent), var(--success)); border-radius:4px; transition:width 0.5s;"></div>
              </div>
            </div>

            <!-- Char breakdown -->
            <div>
              <div style="font-size:0.75rem; color:var(--text3); font-weight:600; text-transform:uppercase; letter-spacing:0.05em; margin-bottom:10px;">Breakdown Karakter</div>
              <div style="display:flex; flex-wrap:wrap; gap:6px;">
                <% result.char_details.forEach(function(cd) { %>
                  <div style="padding:6px 10px; border-radius:6px; font-family:'JetBrains Mono',monospace; font-size:0.85rem; font-weight:600;
                    background:<%= cd.found ? 'rgba(16,185,129,0.12)' : 'rgba(239,68,68,0.12)' %>;
                    border:1px solid <%= cd.found ? 'rgba(16,185,129,0.25)' : 'rgba(239,68,68,0.25)' %>;
                    color:<%= cd.found ? 'var(--success)' : 'var(--danger)' %>;"
                    title="<%= cd.found ? 'Ditemukan' : 'Tidak ditemukan' %> di Input 2">
                    '<%= cd.char %>'
                    <span style="font-size:0.65rem; margin-left:3px;"><%= cd.found ? '✓' : '✗' %></span>
                  </div>
                <% }); %>
              </div>
              <div style="margin-top:12px; font-size:0.8rem; color:var(--text2);">
                <span style="color:var(--success);">■</span> Cocok: <%= result.matched_chars.join(', ') || '-' %>
                &nbsp; <span style="color:var(--danger);">■</span> Tidak cocok: <%= result.unmatched_chars.join(', ') || '-' %>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </div>

    <!-- Log history -->
    <div class="card">
      <div class="card-header"><span class="card-title">Riwayat Pengecekan</span></div>
      <div class="table-wrap">
        <table>
          <thead><tr><th>Input 1</th><th>Input 2</th><th>Tipe</th><th>Match</th><th>Total Unik</th><th>Persentase</th><th>Waktu</th></tr></thead>
          <tbody>
            <% if (logs.length === 0) { %>
              <tr><td colspan="7" style="text-align:center; padding:30px; color:var(--text3);">Belum ada riwayat</td></tr>
            <% } %>
            <% logs.forEach(function(log) { %>
              <tr>
                <td class="mono" style="color:var(--accent);"><%= log.input1 %></td>
                <td class="mono" style="max-width:150px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap;" title="<%= log.input2 %>"><%= log.input2 %></td>
                <td><span class="badge <%= log.type === 'sensitive' ? 'badge-warning' : 'badge-info' %>"><%= log.type === 'sensitive' ? 'Case Sensitive' : 'Case Insensitive' %></span></td>
                <td class="mono" style="color:var(--success);"><%= log.match_count %></td>
                <td class="mono"><%= log.total_unique %></td>
                <td>
                  <span class="mono" style="font-weight:700; color:<%= log.percentage >= 50 ? 'var(--success)' : log.percentage > 0 ? 'var(--warning)' : 'var(--danger)' %>;">
                    <%= log.percentage %>%
                  </span>
                </td>
                <td style="color:var(--text3); font-size:0.78rem;"><%= new Date(log.created_at).toLocaleString('id-ID') %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>

<script>
  // Update radio button border color on change
  document.querySelectorAll('input[name="type"]').forEach(radio => {
    radio.addEventListener('change', () => {
      document.querySelectorAll('input[name="type"]').forEach(r => {
        r.closest('label').style.borderColor = r.checked ? 'var(--accent)' : 'var(--border)';
      });
    });
  });
</script>

<%- include('../partials/footer') %>
