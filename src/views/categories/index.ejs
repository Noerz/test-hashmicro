<%- include('../partials/header') %>
<div class="main">
  <div class="topbar"><span class="page-title">🏷️ Manajemen Kategori</span></div>
  <div class="content">
    <% if (success && success.length > 0) { %><div class="alert alert-success"><%= success[0] %></div><% } %>
    <% if (error && error.length > 0) { %><div class="alert alert-danger"><%= error[0] %></div><% } %>
    <div class="page-header">
      <h1>Daftar Kategori</h1>
      <a href="/categories/create" class="btn btn-primary">+ Tambah Kategori</a>
    </div>
    <div class="card">
      <div class="table-wrap">
        <table>
          <thead><tr><th>#</th><th>Nama Kategori</th><th>Deskripsi</th><th>Jumlah Produk</th><th>Total Nilai</th><th>Aksi</th></tr></thead>
          <tbody>
            <% if (categories.length === 0) { %>
              <tr><td colspan="6" style="text-align:center; padding:40px; color:var(--text3);">Belum ada kategori</td></tr>
            <% } %>
            <% categories.forEach(function(c, i) { %>
              <tr>
                <td class="mono" style="color:var(--text3);"><%= i+1 %></td>
                <td style="font-weight:600;"><%= c.name %></td>
                <td style="color:var(--text2); max-width:200px;"><%= c.description || '-' %></td>
                <td><span class="badge badge-info"><%= c.product_count %> produk</span></td>
                <td class="mono" style="color:var(--success);">Rp <%= c.total_value.toLocaleString('id-ID') %></td>
                <td>
                  <div style="display:flex; gap:6px;">
                    <a href="/categories/<%= c.id %>/edit" class="btn btn-sm btn-warning">Edit</a>
                    <form action="/categories/<%= c.id %>?_method=DELETE" method="POST" class="action-form delete-form">
                      <button type="submit" class="btn btn-sm btn-danger">Hapus</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
